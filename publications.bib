	title = {Experimental comparison of slip detection strategies by tactile sensing with the {BioTac}® on the {DLR} hand arm system},
	url = {https://ieeexplore.ieee.org/abstract/document/6907252?casa_token=uC2ope9q_Y8AAAAA:DFIaxjYbZy7AN6TNX91pUTE_zdOyQA99AYTDaQhrwolWgNP71C9qhyWPp6WCIOm9Bbo6fyJX5D13},
	doi = {10.1109/ICRA.2014.6907252},
	abstract = {Dexterous manipulation of everyday objects requires a precise tactile sense. Slip detection is mandatory to overcome uncertainty and compensate for external disturbances. We compare three different approaches for detecting slip. The methods are model-based slip detection via friction cones, vibration-based detection via bandpass filtering, and a common learning algorithm. They are implemented and tested on a tendon-driven two-finger setup equipped with two tactile BioTac® sensors. Several experiments are conducted to evaluate each approach. The characteristics of the methods are discussed and compared.},
