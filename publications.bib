	url = {https://ieeexplore.ieee.org/abstract/document/10364337},
	doi = {10.1109/ICDL55364.2023.10364337},
	abstract = {Robotic capacities in object manipulation are incomparable to those of humans. Besides years of learning, humans rely heavily on the richness of information from physical interaction with the environment. In particular, tactile sensing is crucial in providing such rich feedback. Despite its potential contributions to robotic manipulation, tactile sensing is less exploited; mainly due to the complexity of the time series provided by tactile sensors. In this work, we propose a method for assessing grasp stability using tactile sensing. More specifically, we propose a methodology to extract task-relevant features and design efficient classifiers to detect object slippage with respect to individual fingertips. We compare two classification models: support vector machine and logistic regression. We use highly sensitive Uskin tactile sensors mounted on an Allegro hand to test and validate our method. Our results demonstrate that the proposed method is effective in slippage detection in an online fashion.},
	urldate = {2024-04-22},
	booktitle = {2023 {IEEE} {International} {Conference} on {Development} and {Learning} ({ICDL})},
	author = {Kitouni, Dounia and Khoramshahi, Mahdi and Perdereau, Veronique},
	month = nov,
	year = {2023},
	keywords = {Tactile sensing, Tactile sensors, Feature extraction, Grasp stability, Logistic regression, Predictive models, Slip detection, Stability analysis, Support vector machines, Tracking, underactuated robotic hands},
	pages = {324--330},
	file = {IEEE Xplore Abstract Record:C\:\\Users\\USER\\Zotero\\storage\\6IHUM3C8\\10364337.html:text/html;IEEE Xplore Full Text PDF:C\:\\Users\\USER\\Zotero\\storage\\LXG3UPGG\\Kitouni et al. - 2023 - A Model-Free Approach to Fingertip Slip and Distur.pdf:application/pdf},
}

@misc{li_incipient_2024,
	title = {Incipient {Slip}-{Based} {Rotation} {Measurement} via {Visuotactile} {Sensing} {During} {In}-{Hand} {Object} {Pivoting}},
	url = {http://arxiv.org/abs/2309.05366},
	doi = {10.48550/arXiv.2309.05366},
	abstract = {In typical in-hand manipulation tasks represented by object pivoting, the real-time perception of rotational slippage has been proven beneficial for improving the dexterity and stability of robotic hands. An effective strategy is to obtain the contact properties for measuring rotation angle through visuotactile sensing. However, existing methods for rotation estimation did not consider the impact of the incipient slip during the pivoting process, which introduces measurement errors and makes it hard to determine the boundary between stable contact and macro slip. This paper describes a generalized 2-d contact model under pivoting, and proposes a rotation measurement method based on the line-features in the stick region. The proposed method was applied to the Tac3D vision-based tactile sensors using continuous marker patterns. Experiments show that the rotation measurement system could achieve an average static measurement error of 0.17 degree and an average dynamic measurement error of 1.34 degree. Besides, the proposed method requires no training data and can achieve real-time sensing during the in-hand object pivoting.},
	urldate = {2024-04-22},
